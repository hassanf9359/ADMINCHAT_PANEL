# ===== Database =====
POSTGRES_DB=adminchat
POSTGRES_USER=adminchat
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://adminchat:change_me_strong_password@postgres:5432/adminchat

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== JWT Authentication =====
JWT_SECRET_KEY=change_me_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Telegram Bot =====
# Bot mode: "webhook" for production, "polling" for development
BOT_MODE=webhook
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook/bot

# ===== Cloudflare Turnstile =====
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
TURNSTILE_TTL_DAYS=30

# ===== Media Cache =====
MEDIA_CACHE_TTL_DAYS=7
MEDIA_CACHE_DIR=/app/media

# ===== Initial Admin Account =====
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change_me_initial_password

# ===== Caddy (optional, used in Caddyfile) =====
SITE_ADDRESS=yourdomain.com

# ===== AI (optional) =====
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-xxx
# AI_MODEL=gpt-4o-mini

# ===== RAG (optional, requires Dify or other provider) =====
# RAG_PROVIDER=dify
# DIFY_BASE_URL=http://docker-api-1:5001/v1
# DIFY_API_KEY=dataset-xxxxxxxxxxxxxxxx
# DIFY_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# RAG_TOP_K=3
