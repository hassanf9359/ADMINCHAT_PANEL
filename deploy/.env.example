# ============================================================
# ADMINCHAT Panel - Environment Configuration
# Copy this file to .env and modify the values
# ============================================================

# ===== Database =====
# For standalone mode: point to your external PostgreSQL
# For full-stack mode: these create the bundled PostgreSQL
POSTGRES_DB=adminchat
POSTGRES_USER=adminchat
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://adminchat:CHANGE_ME_strong_password_here@postgres:5432/adminchat
# NOTE: If using external PostgreSQL, change "postgres" in DATABASE_URL to your PG host
# Example: postgresql+asyncpg://user:pass@192.168.1.100:5432/adminchat

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
# NOTE: If using external Redis, change "redis" to your Redis host
# Example: redis://192.168.1.100:6379/0
# If Redis has password: redis://:yourpassword@redis:6379/0

# ===== JWT Authentication =====
# IMPORTANT: Generate a random 64-char string for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Telegram Bot =====
# "webhook" for production (requires HTTPS domain)
# "polling" for development or no-domain setups
BOT_MODE=polling
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook/bot

# ===== Cloudflare Turnstile (Optional) =====
# Leave empty to disable Turnstile verification
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_TTL_DAYS=30

# ===== Media Cache =====
MEDIA_CACHE_TTL_DAYS=7
MEDIA_CACHE_DIR=/app/media

# ===== Initial Admin Account =====
# Created automatically on first startup
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ===== Frontend URL (for CORS) =====
CORS_ORIGINS=["http://localhost:3000","http://localhost","https://yourdomain.com"]

# ===== Workers (Production) =====
WORKERS=2

# ===== AI Integration (Optional) =====
# Uncomment and configure to enable AI features
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-xxxx
# AI_MODEL=gpt-4o-mini
